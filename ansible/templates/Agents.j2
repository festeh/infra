[Unit]
Description=My-Agents FastAPI Server
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/my-agents
EnvironmentFile=/opt/my-agents/.env
ExecStart=/usr/local/bin/uv run --frozen python -m my_agents.agents_server
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
