#!/usr/bin/env bash
set -euo pipefail

vault_id=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --vault-id)
      vault_id="${2:-}"
      shift 2
      ;;
    *)
      echo "Unsupported vault password client argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -n "$vault_id" && "$vault_id" != "production" ]]; then
  echo "Unsupported vault ID: $vault_id" >&2
  exit 2
fi

env_file="${DOTFILES_ENV_FILE:-$HOME/dotfiles/.env}"
if [[ ! -f "$env_file" || ! -r "$env_file" ]]; then
  echo "Vault password source is not readable: $env_file" >&2
  exit 1
fi

if [[ "$(stat -c '%u' "$env_file")" != "$(id -u)" ]]; then
  echo "Vault password source must be owned by the current user: $env_file" >&2
  exit 1
fi

permissions="$(stat -c '%a' "$env_file")"
if (( (8#$permissions & 8#077) != 0 )); then
  echo "Vault password source must not be accessible by group or others: $env_file" >&2
  exit 1
fi

key_name="ANSIBLE_VAULT_PASSWORD"
match_count="$(awk -F= -v key="$key_name" '$1 == key { count++ } END { print count + 0 }' "$env_file")"
if [[ "$match_count" != "1" ]]; then
  echo "Expected exactly one $key_name entry in $env_file" >&2
  exit 1
fi

vault_password="$(awk -F= -v key="$key_name" '$1 == key { sub(/^[^=]*=/, ""); print }' "$env_file")"
vault_password="${vault_password%$'\r'}"
if [[ -z "$vault_password" ]]; then
  echo "$key_name is empty in $env_file" >&2
  exit 1
fi

printf '%s\n' "$vault_password"
