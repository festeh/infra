# Managed by Ansible. The complete site is static; no application listener exists.
{{ dimalip_domains | join(', ') }} {
	import infra_site
	encode zstd gzip

	@obsolete_api path /api /api/*
	handle @obsolete_api {
		respond 404
	}

	@immutable_assets path /assets/*
	header @immutable_assets Cache-Control "public, max-age=31536000, immutable"
	@vue_routes path /about /about/

	handle {
		header {
			Referrer-Policy "strict-origin-when-cross-origin"
			X-Frame-Options "DENY"
		}
		root * {{ dimalip_current_path }}/dist
		rewrite @vue_routes /index.html
		file_server
	}
}
