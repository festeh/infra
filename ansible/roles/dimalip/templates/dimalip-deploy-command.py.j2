#!/usr/bin/python3
"""Restricted, checksum-addressed static release receiver and activator."""

from __future__ import annotations

import fcntl
import hashlib
import os
from pathlib import Path, PurePosixPath
import re
import shutil
import shlex
import sys
import tarfile
from typing import NoReturn


INCOMING = Path({{ dimalip_incoming_directory | to_json }})
RELEASES = Path({{ dimalip_release_root | to_json }})
CURRENT = Path({{ dimalip_current_path | to_json }})
LOCK_PATH = Path({{ (dimalip_deploy_home ~ '/activate.lock') | to_json }})
RELEASE_RETENTION = {{ dimalip_release_retention }}
MAX_ARTIFACT_BYTES = {{ dimalip_max_artifact_bytes }}
MAX_EXTRACTED_BYTES = {{ dimalip_max_extracted_bytes }}
MAX_ARCHIVE_MEMBERS = {{ dimalip_max_archive_members }}
RELEASE_ID_PATTERN = re.compile(r"^[0-9a-f]{64}$")
ALLOWED_TOP_LEVEL_PATHS = {"REVISION", "dist"}


def fail(message: str) -> NoReturn:
    print(f"deployment rejected: {message}", file=sys.stderr)
    raise SystemExit(1)


def validate_release_id(value: str) -> str:
    if not RELEASE_ID_PATTERN.fullmatch(value):
        fail("release ID must be a lowercase SHA-256 digest")
    return value


def receive(release_id: str) -> None:
    destination = INCOMING / f"{release_id}.tar.gz"
    temporary = INCOMING / f".{release_id}.{os.getpid()}.upload"
    digest = hashlib.sha256()
    received = 0

    try:
        with temporary.open("xb") as output:
            while chunk := sys.stdin.buffer.read(1024 * 1024):
                received += len(chunk)
                if received > MAX_ARTIFACT_BYTES:
                    fail("artifact exceeds the configured size limit")
                digest.update(chunk)
                output.write(chunk)
            output.flush()
            os.fsync(output.fileno())

        if received == 0:
            fail("artifact is empty")
        if digest.hexdigest() != release_id:
            fail("artifact checksum does not match its release ID")

        os.chmod(temporary, 0o600)
        os.replace(temporary, destination)
    finally:
        temporary.unlink(missing_ok=True)

    print(release_id)


def validated_members(archive: tarfile.TarFile) -> list[tarfile.TarInfo]:
    members = archive.getmembers()
    if len(members) > MAX_ARCHIVE_MEMBERS:
        fail("archive contains too many members")

    seen: set[str] = set()
    extracted_bytes = 0
    has_revision = False
    has_index = False

    for member in members:
        if "\\" in member.name:
            fail("archive member contains a backslash")

        member_path = PurePosixPath(member.name)
        if member_path.is_absolute() or not member_path.parts:
            fail("archive member path is not relative")
        if any(part in {"", ".", ".."} for part in member_path.parts):
            fail("archive member path contains an unsafe component")
        if member_path.parts[0] not in ALLOWED_TOP_LEVEL_PATHS:
            fail("archive contains an unexpected top-level path")
        if member_path.parts[0] == "REVISION" and len(member_path.parts) != 1:
            fail("REVISION must be a regular top-level file")
        if not (member.isdir() or member.isreg()):
            fail("archive may contain only directories and regular files")
        if member.name in seen:
            fail("archive contains a duplicate member")

        seen.add(member.name)
        extracted_bytes += member.size
        if extracted_bytes > MAX_EXTRACTED_BYTES:
            fail("archive expands beyond the configured size limit")

        has_revision = has_revision or member.name == "REVISION"
        has_index = has_index or member.name == "dist/index.html"

    if not has_revision or not has_index:
        fail("archive requires REVISION and dist/index.html")
    return members


def extract_release(artifact: Path, release_id: str) -> Path:
    release_path = RELEASES / release_id
    if release_path.is_dir():
        return release_path
    if release_path.exists():
        fail("release destination exists but is not a directory")

    temporary = RELEASES / f".{release_id}.{os.getpid()}.extract"
    if temporary.exists():
        shutil.rmtree(temporary)
    temporary.mkdir(mode=0o755)

    try:
        with tarfile.open(artifact, mode="r:gz") as archive:
            members = validated_members(archive)
            for member in members:
                member_path = PurePosixPath(member.name)
                destination = temporary.joinpath(*member_path.parts)

                if member.isdir():
                    destination.mkdir(mode=0o755, parents=True, exist_ok=True)
                    continue

                destination.parent.mkdir(mode=0o755, parents=True, exist_ok=True)
                source = archive.extractfile(member)
                if source is None:
                    fail("could not read a regular archive member")
                with source, destination.open("xb") as output:
                    shutil.copyfileobj(source, output)
                os.chmod(destination, 0o644)

        revision = (temporary / "REVISION").read_text(encoding="utf-8").strip()
        if not revision or len(revision) > 128 or not revision.isprintable():
            fail("REVISION contains an invalid build identifier")

        os.rename(temporary, release_path)
    finally:
        if temporary.exists():
            shutil.rmtree(temporary)

    return release_path


def active_release_id() -> str:
    if not CURRENT.is_symlink():
        fail("no release is active")

    resolved = CURRENT.resolve(strict=True)
    if resolved.parent != RELEASES.resolve(strict=True):
        fail("active release points outside the managed release directory")
    return validate_release_id(resolved.name)


def prune_releases(active_id: str) -> None:
    releases = sorted(
        (
            path
            for path in RELEASES.iterdir()
            if path.is_dir() and RELEASE_ID_PATTERN.fullmatch(path.name)
        ),
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    )
    retained = {active_id}
    for release in releases:
        if len(retained) >= RELEASE_RETENTION:
            break
        retained.add(release.name)
    for release in releases:
        if release.name not in retained:
            shutil.rmtree(release)


def activate(release_id: str) -> None:
    artifact = INCOMING / f"{release_id}.tar.gz"
    if not artifact.is_file() or artifact.is_symlink():
        fail("uploaded artifact is missing or invalid")
    if artifact.stat().st_size > MAX_ARTIFACT_BYTES:
        fail("uploaded artifact exceeds the configured size limit")

    digest = hashlib.sha256()
    with artifact.open("rb") as source:
        while chunk := source.read(1024 * 1024):
            digest.update(chunk)
    if digest.hexdigest() != release_id:
        fail("uploaded artifact changed after receipt")

    release_path = extract_release(artifact, release_id)
    temporary_link = CURRENT.with_name(f".{CURRENT.name}.{os.getpid()}.new")
    temporary_link.unlink(missing_ok=True)
    temporary_link.symlink_to(release_path)
    os.replace(temporary_link, CURRENT)
    artifact.unlink()
    prune_releases(release_id)
    print(release_id)


def main() -> None:
    try:
        command = shlex.split(os.environ.get("SSH_ORIGINAL_COMMAND", ""))
    except ValueError as error:
        fail(f"invalid command: {error}")

    if len(command) == 2 and command[0] == "upload":
        receive(validate_release_id(command[1]))
        return

    with LOCK_PATH.open("a+") as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        if command == ["status"]:
            print(active_release_id())
            return
        if len(command) == 2 and command[0] == "activate":
            activate(validate_release_id(command[1]))
            return

    fail("only upload, activate, and status are allowed")


if __name__ == "__main__":
    main()
